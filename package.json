    "express": "^4.18.2",
    "fluent-ffmpeg": "^2.1.2",
    "googleapis": "^131.0.0",
    "node-appwrite": "^13.0.0",
    "openai": "^6.15.0"
  },
  "devDependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0"
  }
