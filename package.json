{
  "name": "crunsh-lofi-automation",
  "version": "1.0.0",
  "description": "Fully automated lofi automation for \"Crunsh.\" channel via Youtube",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "npm run build && node dist/index.js",
    "dev": "tsc --watch & node --watch dist/index.js",
    "interactive": "npm run build && node dist/index.js -- --interactive",
    "interactive-no-upload": "npm run build && node dist/index.js -- --interactive --no-upload",
    "no-upload": "npm run build && node dist/index.js -- --no-upload",
    "youtube-auth": "npm run build && node dist/scripts/get-youtube-token.js",
    "setup-airtable": "npm run build && node dist/scripts/setup-airtable.js",
    "test-upload": "npm run build && node dist/scripts/test-upload.js"
  },
  "keywords": [
    "lofi",
    "youtube",
    "automation",
    "video",
    "ffmpeg"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.6",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@ffprobe-installer/ffprobe": "^1.4.1",
    "@google/generative-ai": "^0.24.1",
    "@napi-rs/canvas": "^0.1.56",
    "airtable": "^0.12.2",
    "axios": "^1.6.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "fluent-ffmpeg": "^2.1.2",
    "googleapis": "^131.0.0",
    "inquirer": "^13.2.1",
    "openai": "^6.15.0"
  }
}
